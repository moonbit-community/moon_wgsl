%derive<Debug> Token
%derive<Debug> ParseError
%position<Int>
%start<ExpressionParseNode> parse_expression

%token<String> IDENT
%token<String> NUMBER
%token<String> TEMPLATE
%token TRUE        "true"
%token FALSE       "false"
%token LEFT_PAREN  "("
%token RIGHT_PAREN ")"
%token LEFT_BRACKET  "["
%token RIGHT_BRACKET "]"
%token DOT         "."
%token COMMA       ","
%token DOUBLE_COLON "::"
%token LESS        "<"
%token LESS_EQUAL  "<="
%token SHIFT_LEFT  "<<"
%token GREATER     ">"
%token GREATER_EQUAL ">="
%token SHIFT_RIGHT ">>"
%token PLUS        "+"
%token MINUS       "-"
%token MINUS_MINUS "--"
%token STAR        "*"
%token SLASH       "/"
%token PERCENT     "%"
%token BANG        "!"
%token TILDE       "~"
%token AMP         "&"
%token AMP_AMP     "&&"
%token PIPE        "|"
%token PIPE_PIPE   "||"
%token CARET       "^"
%token EQUAL_EQUAL "=="
%token BANG_EQUAL  "!="

%type<ExpressionParseNode> expression
%type<ExpressionParseNode> short_circuit_or
%type<ExpressionParseNode> short_circuit_and
%type<ExpressionParseNode> bitwise_or
%type<ExpressionParseNode> bitwise_xor
%type<ExpressionParseNode> bitwise_and
%type<ExpressionParseNode> equality
%type<ExpressionParseNode> relational
%type<ExpressionParseNode> shift
%type<ExpressionParseNode> additive
%type<ExpressionParseNode> multiplicative
%type<ExpressionParseNode> unary
%type<ExpressionParseNode> postfix
%type<ExpressionPostfixSuffix> postfix_suffix
%type<ExpressionParseNode> primary
%type<ExpressionTypeParseNode> path_ident
%type<Array[ExpressionParseNode]> argument_list
%type<Array[ExpressionParseNode]> opt_arguments
%type<ExpressionParseNode> literal

%%

parse_expression
  : expression                    { $1 }
  ;

expression
  : short_circuit_or              { $1 }
  ;

short_circuit_or
  : short_circuit_and             { $1 }
  | short_circuit_or "||" short_circuit_and
                                  { ExpressionParseNode::Binary(ExpressionBinaryOperator::ShortCircuitOr, $1, $3) }
  ;

short_circuit_and
  : bitwise_or                    { $1 }
  | short_circuit_and "&&" bitwise_or
                                  { ExpressionParseNode::Binary(ExpressionBinaryOperator::ShortCircuitAnd, $1, $3) }
  ;

bitwise_or
  : bitwise_xor                   { $1 }
  | bitwise_or "|" bitwise_xor    { ExpressionParseNode::Binary(ExpressionBinaryOperator::BitwiseOr, $1, $3) }
  ;

bitwise_xor
  : bitwise_and                   { $1 }
  | bitwise_xor "^" bitwise_and   { ExpressionParseNode::Binary(ExpressionBinaryOperator::BitwiseXor, $1, $3) }
  ;

bitwise_and
  : equality                      { $1 }
  | bitwise_and "&" equality      { ExpressionParseNode::Binary(ExpressionBinaryOperator::BitwiseAnd, $1, $3) }
  ;

equality
  : relational                    { $1 }
  | equality "==" relational      { ExpressionParseNode::Binary(ExpressionBinaryOperator::Equality, $1, $3) }
  | equality "!=" relational      { ExpressionParseNode::Binary(ExpressionBinaryOperator::Inequality, $1, $3) }
  ;

relational
  : shift                         { $1 }
  | relational "<" shift          { ExpressionParseNode::Binary(ExpressionBinaryOperator::LessThan, $1, $3) }
  | relational "<=" shift         { ExpressionParseNode::Binary(ExpressionBinaryOperator::LessThanEqual, $1, $3) }
  | relational ">" shift          { ExpressionParseNode::Binary(ExpressionBinaryOperator::GreaterThan, $1, $3) }
  | relational ">=" shift         { ExpressionParseNode::Binary(ExpressionBinaryOperator::GreaterThanEqual, $1, $3) }
  ;

shift
  : additive                      { $1 }
  | shift "<<" additive           { ExpressionParseNode::Binary(ExpressionBinaryOperator::ShiftLeft, $1, $3) }
  | shift ">>" additive           { ExpressionParseNode::Binary(ExpressionBinaryOperator::ShiftRight, $1, $3) }
  ;

additive
  : multiplicative                { $1 }
  | additive "+" multiplicative   { ExpressionParseNode::Binary(ExpressionBinaryOperator::Addition, $1, $3) }
  | additive "-" multiplicative   { ExpressionParseNode::Binary(ExpressionBinaryOperator::Subtraction, $1, $3) }
  | additive "--" multiplicative  { ExpressionParseNode::Binary(ExpressionBinaryOperator::Subtraction, $1, ExpressionParseNode::Unary(ExpressionUnaryOperator::Negation, $3)) }
  ;

multiplicative
  : unary                         { $1 }
  | multiplicative "*" unary      { ExpressionParseNode::Binary(ExpressionBinaryOperator::Multiplication, $1, $3) }
  | multiplicative "/" unary      { ExpressionParseNode::Binary(ExpressionBinaryOperator::Division, $1, $3) }
  | multiplicative "%" unary      { ExpressionParseNode::Binary(ExpressionBinaryOperator::Remainder, $1, $3) }
  ;

unary
  : postfix                       { $1 }
  | "-" unary                     { ExpressionParseNode::Unary(ExpressionUnaryOperator::Negation, $2) }
  | "!" unary                     { ExpressionParseNode::Unary(ExpressionUnaryOperator::LogicalNegation, $2) }
  | "~" unary                     { ExpressionParseNode::Unary(ExpressionUnaryOperator::BitwiseComplement, $2) }
  | "*" unary                     { ExpressionParseNode::Unary(ExpressionUnaryOperator::Indirection, $2) }
  | "&" unary                     { ExpressionParseNode::Unary(ExpressionUnaryOperator::AddressOf, $2) }
  ;

postfix
  : primary                       { $1 }
  | postfix postfix_suffix        { $1.apply_postfix($2) }
  ;

postfix_suffix
  : "[" expression "]"            { ExpressionPostfixSuffix::Indexing($2) }
  | "." IDENT                     { ExpressionPostfixSuffix::NamedComponent($2) }
  ;

primary
  : literal                       { $1 }
  | path_ident                    { ExpressionParseNode::TypeOrIdentifier($1) }
  | path_ident "(" opt_arguments ")"
                                  { ExpressionParseNode::FunctionCall(ExpressionFunctionCallParseNode::{ callee: $1, arguments: $3 }) }
  | path_ident TEMPLATE "(" opt_arguments ")"
                                  { ExpressionParseNode::FunctionCall(ExpressionFunctionCallParseNode::{ callee: $1.with_template($2), arguments: $4 }) }
  | "(" expression ")"            { ExpressionParseNode::Parenthesized($2) }
  ;

path_ident
  : IDENT                         { ExpressionTypeParseNode::from_path([$1]) }
  | path_ident "::" IDENT         { $1.qualified_child($3) }
  ;

opt_arguments
  :                              { [] }
  | argument_list                { $1 }
  | argument_list ","            { $1 }
  ;

argument_list
  : expression                   { [$1] }
  | argument_list "," expression { $1.push($3); $1 }
  ;

literal
  : NUMBER                       { ExpressionParseNode::Literal($1) }
  | "true"                       { ExpressionParseNode::Bool(true) }
  | "false"                      { ExpressionParseNode::Bool(false) }
  ;
