t cc09 = u32(true);\n    let cc10 = f32(1i);\n    let cc11 = f32(1u);\n    let cc12 = f32(1);\n    let cc13 = f32(1.0);\n    let cc14 = f32(true);\n    let cc15 = bool(1i);\n    let cc16 = bool(1u);\n    let cc17 = bool(1f);\n    let cc18 = bool(1);\n    let cc19 = bool(1.0);\n}\n",
