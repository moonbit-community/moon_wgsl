    wesl_sources: [
      (
        "./main.wgsl", "fn main() { @if(true) package::foo::func(); @if(false) package::bar::func(); }",
      ),
      ("./foo.wgsl", "const_assert 0 < 1; fn func() {}"),
      ("./bar.wgsl", "const_assert 1 < 2; fn func() {}"),
    ],
    expected_wgsl: Some(
      "const_assert 0 < 1; fn main() { func(); } fn func() {}",
    ),
    expected_underscore_wgsl: Some(
      "const_assert 0 < 1; fn main() { package_foo_func(); } fn package_foo_func() {}",
    ),
  },
