///|
let upstream_import_cases : Array[UpstreamModuleCase] = [
  UpstreamModuleCase::{
    name: "import package::bar::foo;",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      ("./main.wgsl", "import package::bar::foo; fn main() { foo(); }"),
      ("./bar.wgsl", "fn foo() { }"),
    ],
    expected_wgsl: Some("fn main() { foo(); } fn foo() { }"),
    expected_underscore_wgsl: Some(
      "fn main() { package_bar_foo(); } fn package_bar_foo() { }",
    ),
  },
  UpstreamModuleCase::{
    name: "main has other root elements",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      (
        "./main.wgsl", "struct Uniforms { a: u32 } @group(0) @binding(0) var<uniform> u: Uniforms; fn main() { }",
      ),
    ],
    expected_wgsl: Some(
      "struct Uniforms { a: u32 } @group(0) @binding(0) var<uniform> u: Uniforms; fn main() { }",
    ),
    expected_underscore_wgsl: Some(
      "struct Uniforms { a: u32 } @group(0) @binding(0) var<uniform> u: Uniforms; fn main() { }",
    ),
  },
  UpstreamModuleCase::{
    name: "import foo as bar",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      ("./main.wgsl", "import package::file1::foo as bar; fn main() { bar(); }"),
      ("./file1.wgsl", "fn foo() { /* fooImpl */ }"),
    ],
    expected_wgsl: Some("fn main() { bar(); } fn bar() { /* fooImpl */ }"),
    expected_underscore_wgsl: Some(
      "fn main() { package_file1_foo(); } fn package_file1_foo() { /* fooImpl */ }",
    ),
  },
  UpstreamModuleCase::{
    name: "import twice doesn't get two copies",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      (
        "./main.wgsl", "import package::file1::foo; import package::file2::bar; fn main() { foo(); bar(); }",
      ),
      ("./file1.wgsl", "fn foo() { /* fooImpl */ }"),
      ("./file2.wgsl", "import package::file1::foo; fn bar() { foo(); }"),
    ],
    expected_wgsl: Some(
      "fn main() { foo(); bar(); } fn foo() { /* fooImpl */ } fn bar() { foo(); }",
    ),
    expected_underscore_wgsl: Some(
      "fn main() { package_file1_foo(); package_file2_bar(); } fn package_file1_foo() { /* fooImpl */ } fn package_file2_bar() { package_file1_foo(); }",
    ),
  },
  UpstreamModuleCase::{
    name: "imported fn calls support fn with root conflict",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      (
        "./main.wgsl", "import package::file1::foo; fn main() { foo(); } fn conflicted() { }",
      ),
      (
        "./file1.wgsl", "fn foo() { conflicted(0); conflicted(1); } fn conflicted(a:i32) {}",
      ),
    ],
    expected_wgsl: Some(
      "fn main() { foo(); } fn conflicted() { } fn foo() { conflicted0(0); conflicted0(1); } fn conflicted0(a:i32) {}",
    ),
    expected_underscore_wgsl: Some(
      "fn main() { package_file1_foo(); } fn conflicted() { } fn package_file1_foo() { package_file1_conflicted(0); package_file1_conflicted(1); } fn package_file1_conflicted(a:i32) {}",
    ),
  },
  UpstreamModuleCase::{
    name: "import twice with two as names",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      (
        "./main.wgsl", "import package::file1::foo as bar; import package::file1::foo as zap; fn main() { bar(); zap(); }",
      ),
      ("./file1.wgsl", "fn foo() { }"),
    ],
    expected_wgsl: Some("fn main() { bar(); bar(); } fn bar() { }"),
    expected_underscore_wgsl: Some(
      "fn main() { package_file1_foo(); package_file1_foo(); } fn package_file1_foo() { }",
    ),
  },
  UpstreamModuleCase::{
    name: "import transitive conflicts with main",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      (
        "./main.wgsl", "import package::file1::mid; fn main() { mid(); } fn grand() { /* main impl */ }",
      ),
      ("./file1.wgsl", "import package::file2::grand; fn mid() { grand(); }"),
      ("./file2.wgsl", "fn grand() { /* grandImpl */ }"),
    ],
    expected_wgsl: Some(
      "fn main() { mid(); } fn grand() { /* main impl */ } fn mid() { grand0(); } fn grand0() { /* grandImpl */ }",
    ),
    expected_underscore_wgsl: Some(
      "fn main() { package_file1_mid(); } fn grand() { /* main impl */ } fn package_file1_mid() { package_file2_grand(); } fn package_file2_grand() { /* grandImpl */ }",
    ),
  },
  UpstreamModuleCase::{
    name: "multiple exports from the same module",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      (
        "./main.wgsl", "import package::file1::{foo, bar}; fn main() { foo(); bar(); }",
      ),
