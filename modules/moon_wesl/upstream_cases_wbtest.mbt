///|
priv struct UpstreamParsingCase {
  name : String
  source : String
  fails : Bool
}

///|
priv struct UpstreamSyntaxSpecCase {
  suite : String
  name : String
  description : String
  syntax_kind : String
  code : String
  expect_pass : Bool
}

///|
priv struct UpstreamEvalSpecCase {
  suite : String
  name : String
  description : String
  code : String
  eval : String
  expected_result : String?
  expect_pass : Bool
  stage : String?
}

///|
priv struct UpstreamModuleCase {
  name : String
  notes : String?
  requires_eager : Bool
  wesl_sources : Array[(String, String)]
  expected_wgsl : String?
  expected_underscore_wgsl : String?
}

///|
priv struct UpstreamContextCase {
  name : String
  description : String
  source : String
  expect_pass : Bool
  lower : Bool
}

///|
priv struct UpstreamBulkCase {
  name : String
  base_dir : String
  git_url : String?
  git_revision : String?
  include_paths : Array[String]
  exclude_paths : Array[String]
}

///|
priv struct UpstreamE2ECase {
  suite : String
  path : String
  source : String
}

