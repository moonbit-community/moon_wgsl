e can be omitted\n    }\n\n    loop {\n        switch x {\n            case 1: {}\n            case 2: {\n                switch y {\n                    case 1: {\n                        continue;\n                    }\n                    default: {\n                        switch z {\n                            case 1: {\n                                pos = 2;\n                            }\n                            default: {}\n                        }\n                        // check here can be omitted\n                    }\n                }\n                // check needs to be generated here\n            }\n            default: {}\n        }\n        // check needs to be generated here\n    }\n}\n",
