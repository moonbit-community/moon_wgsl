f = pow(1, 1f);\n  var pow_afai = pow(1.0, 1);\n  var pow_afaf = pow(1.0, 1.0);\n  var pow_aff = pow(1.0, 1f);\n  var pow_fai = pow(1f, 1);\n  var pow_faf = pow(1f, 1.0);\n  var pow_ff = pow(1f, 1f);\n}\n",
