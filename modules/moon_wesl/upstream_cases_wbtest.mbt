      (
        "./util.wgsl", "const foo = 10; const bar = 10; fn func() { @if(true) let foo = 20; let x = foo; /* foo is shadowed. */ @if(false) let bar = 20; let y = bar; /* bar is not shadowed. */ }",
      ),
    ],
    expected_wgsl: Some(
      "fn main() { func(); } fn func() { let foo = 20; let x = foo; /* foo is shadowed. */ let y = bar; /* bar is not shadowed. */ } const bar = 10;",
    ),
    expected_underscore_wgsl: Some(
      "fn main() { package_util_func(); } fn package_util_func() { let foo = 20; let x = foo; /* foo is shadowed. */ let y = package_util_bar; /* bar is not shadowed. */ } const package_util_bar = 10;",
    ),
  },
  UpstreamModuleCase::{
    name: "conditional import of const_assert",
