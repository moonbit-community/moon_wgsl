///|
let upstream_dead_code_cases : Array[UpstreamModuleCase] = [
  UpstreamModuleCase::{
    name: "strip-unused-declaration",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      ("./main.wgsl", "import package::m1::foo; fn main() { foo(); }"),
      ("./m1.wgsl", "fn foo() { } fn bar() { }"),
    ],
    expected_wgsl: Some("fn main() { foo(); } fn foo() { }"),
    expected_underscore_wgsl: Some(
      "fn main() { package_m1_foo(); } fn package_m1_foo() { }",
    ),
  },
  UpstreamModuleCase::{
    name: "strip-unused-module",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      ("./main.wgsl", "import package::m1::foo; fn main() { foo(); }"),
      (
        "./m1.wgsl", "import package::m2::bar; fn foo() { } fn unused() { bar(); }",
      ),
      ("./m2.wgsl", "const_assert false; fn bar() { }"),
    ],
    expected_wgsl: Some("fn main() { foo(); } fn foo() { }"),
    expected_underscore_wgsl: Some(
      "fn main() { package_m1_foo(); } fn package_m1_foo() { }",
    ),
  },
  UpstreamModuleCase::{
    name: "keep-const-asserts",
    notes: None,
    requires_eager: false,
    wesl_sources: [
      ("./main.wgsl", "import package::m1::foo; fn main() { foo(); }"),
      ("./m1.wgsl", "const_assert true; fn foo() { } fn bar() { }"),
    ],
    expected_wgsl: Some("fn main() { foo(); } fn foo() { }"),
    expected_underscore_wgsl: Some(
      "fn main() { package_m1_foo(); } const_assert true; fn package_m1_foo() { }",
    ),
  },
]

