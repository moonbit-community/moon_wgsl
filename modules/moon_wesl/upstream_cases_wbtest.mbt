    source: "@compute @workgroup_size(1)\nfn main() {}\n\nfn breakIfEmpty() {\n    loop {\n        continuing {\n            break if true;\n        }\n    }\n}\n\nfn breakIfEmptyBody(a: bool) {\n    loop {\n        continuing {\n            var b = a;\n            var c = a != b;\n\n            break if a == c;\n        }\n    }\n}\n\nfn breakIf(a: bool) {\n    loop {\n        var d = a;\n        var e = a != d;\n\n        continuing {\n            break if a == e;\n        }\n    }\n}\n\nfn breakIfSeparateVariable() {\n    var counter = 0u;\n\n    loop {\n        counter += 1u;\n\n        continuing {\n            break if counter == 5u;\n        }\n    }\n}\n",
  },
