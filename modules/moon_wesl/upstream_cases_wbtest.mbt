  UpstreamContextCase::{
    name: "circular-alias",
    description: "an alias cannot have cycles",
    source: "alias foo = bar; alias bar = foo;",
    expect_pass: false,
    lower: false,
  },
  UpstreamContextCase::{
    name: "circular-alias-direct",
    description: "an alias cannot alias itself",
    source: "alias foo = foo;",
    expect_pass: false,
    lower: false,
  },
  UpstreamContextCase::{
    name: "circular-alias-indirect",
    description: "an alias cannot reference itself",
    source: "alias foo = array<foo, 1>;",
    expect_pass: false,
    lower: false,
  },
  UpstreamContextCase::{
    name: "circular-const",
    description: "a global const cannot have cycles",
    source: "const foo: u32 = bar; const bar: u32 = foo;",
    expect_pass: false,
    lower: false,
  },
  UpstreamContextCase::{
    name: "circular-const-indirect",
    description: "a global const cannot reference itself",
    source: "const foo: array<u32, foo[0]> = array(1u);",
    expect_pass: false,
    lower: false,
  },
  UpstreamContextCase::{
    name: "circular-alias-const",
    description: "cycle between an alias and a const",
    source: "alias foo = array<u32, bar[0]>; const bar = array<foo, 1>(1u);",
    expect_pass: false,
    lower: false,
  },
  UpstreamContextCase::{
    name: "circular-var",
    description: "a global var cannot have cycles",
    source: "var<private> foo = bar; const bar = foo;",
    expect_pass: false,
    lower: false,
  },
]

