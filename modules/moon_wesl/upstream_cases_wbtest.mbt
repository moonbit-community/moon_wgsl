    "with comments can be found at https://weber.itn.liu.se/~stegu/jgt2012/article.pdf\n\nfn permute3(x: vec3<f32>) -> vec3<f",
    "32> { return (((x * 34.) + 1.) * x) % vec3<f32>(289.); }\n\nfn snoise2(v: vec2<f32>) -> f32 {\n    let C = vec4<f32>(0.2",
    "11324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);\n    var i: vec2<f32> = floor(v + dot(v, C.yy",
