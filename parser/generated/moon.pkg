import {
  "Milky2018/moon_wgsl/ast",
  "Milky2018/moon_wgsl/common",
  "moonbitlang/core/list",
}

warnings = "-6"

options(
  "pre-build": [
    {
      "command": "$mod_dir/.mooncakes/moonbitlang/yacc/moonyacc --input-mode array $input -o $output && moonfmt -w $output && moonfmt -w $output",
      "input": "wgsl_parser.mbty",
      "output": "wgsl_parser.mbt",
    },
  ],
)
