import {
  "Milky2018/moon_wgsl/ast",
  "Milky2018/moon_wgsl/directive_syntax",
  "Milky2018/moon_wgsl/lex",
  "moonbitlang/core/list",
}

options(
  "pre-build": [
    {
      "command": "$mod_dir/.mooncakes/moonbitlang/yacc/moonyacc $input --input-mode array -o $output && moonfmt -w $output",
      "input": "wgsl_parser.mbty",
      "output": "wgsl_generated_parser.mbt",
    },
  ],
)
