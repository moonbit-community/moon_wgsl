        "*generated_parser.mbt"
      ],
      "forbidden": "Ifdef|Ifndef|DefineImportPath|parse_wgsl_import|WgslImportTarget|ImportDefinition"
    },
    {
      "name": "WGSL Semantic IR compatibility cache ownership",
      "paths": [
        "modules/wgsl/ir"
      ],
      "globs": [
        "*.mbt",
        "*.mbti"
      ],
      "exclude": [
        "*_test.mbt",
        "*_wbtest.mbt"
      ],
      "forbidden": "WgslIrGeneratedImportProvenance|WgslIrImportArenaEvent|WgslIrFinalNameTable|WgslIrLinkGraph|generated_import_provenance|import_arena_events|generated_import\\s*:\\s*Bool|parse_wgsl_module_to_ir_with_generated_imports"
    }
